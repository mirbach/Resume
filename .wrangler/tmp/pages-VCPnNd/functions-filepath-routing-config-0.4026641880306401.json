{
  "routes": [
    {
      "routePath": "/api/themes/:name",
      "mountPath": "/api/themes",
      "method": "DELETE",
      "module": [
        "api/themes/[name].ts:onRequestDelete"
      ]
    },
    {
      "routePath": "/api/themes/:name",
      "mountPath": "/api/themes",
      "method": "GET",
      "module": [
        "api/themes/[name].ts:onRequestGet"
      ]
    },
    {
      "routePath": "/api/themes/:name",
      "mountPath": "/api/themes",
      "method": "PUT",
      "module": [
        "api/themes/[name].ts:onRequestPut"
      ]
    },
    {
      "routePath": "/api/upload/:type",
      "mountPath": "/api/upload",
      "method": "POST",
      "module": [
        "api/upload/[type].ts:onRequestPost"
      ]
    },
    {
      "routePath": "/api/uploads/:filename",
      "mountPath": "/api/uploads",
      "method": "GET",
      "module": [
        "api/uploads/[filename].ts:onRequestGet"
      ]
    },
    {
      "routePath": "/api/health",
      "mountPath": "/api",
      "method": "GET",
      "module": [
        "api/health.ts:onRequestGet"
      ]
    },
    {
      "routePath": "/api/resume",
      "mountPath": "/api",
      "method": "GET",
      "module": [
        "api/resume.ts:onRequestGet"
      ]
    },
    {
      "routePath": "/api/resume",
      "mountPath": "/api",
      "method": "PUT",
      "module": [
        "api/resume.ts:onRequestPut"
      ]
    },
    {
      "routePath": "/api/settings",
      "mountPath": "/api",
      "method": "GET",
      "module": [
        "api/settings.ts:onRequestGet"
      ]
    },
    {
      "routePath": "/api/settings",
      "mountPath": "/api",
      "method": "PUT",
      "module": [
        "api/settings.ts:onRequestPut"
      ]
    },
    {
      "routePath": "/api/themes",
      "mountPath": "/api/themes",
      "method": "GET",
      "module": [
        "api/themes/index.ts:onRequestGet"
      ]
    },
    {
      "routePath": "/api/themes",
      "mountPath": "/api/themes",
      "method": "POST",
      "module": [
        "api/themes/index.ts:onRequestPost"
      ]
    }
  ],
  "baseURL": "/"
}